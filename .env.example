# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Optional runtime controls
ANALYSIS_RATE_LIMIT_MAX="12"
ANALYSIS_RATE_LIMIT_WINDOW_MS="60000"
ANALYSIS_DEDUP_WINDOW_MS="30000"
GEMINI_MODEL_PRIMARY="gemini-3.1-pro-preview"
GEMINI_MODEL_FALLBACK="gemini-2.5-pro"
MAX_FETCH_RETRIES="3"
MIN_HUMAN_DELAY_MS="1200"
APP_AUTH_TOKEN=""
# Required for /login and /ops: admin password and session signing secret.
ADMIN_LOGIN_PASSWORD=""
OPERATOR_LOGIN_PASSWORD=""
VIEWER_LOGIN_PASSWORD=""
APP_SESSION_SECRET=""
APP_SESSION_SECRET_PREVIOUS=""
TURNSTILE_SECRET_KEY=""
ALLOWED_IPS=""
# On Vercel the filesystem is read-only. Use DB_DRIVER=postgres + DATABASE_URL (e.g. Vercel Postgres) for persistence.
DB_DRIVER="file"
SQLITE_DB_PATH="predictions.sqlite"
DATABASE_URL=""
DB_BACKUP_KEEP="7"
WORKER_CRON_SECRET=""
# Optional: used by Vercel Cron /api/cron/scan (falls back to WORKER_CRON_SECRET)
CRON_SECRET=""
# Optional: call POST /api/cron/retrospective daily to run AI Retrospective Engine (learning loop + Telegram report)
AUDIT_LOG_ENABLED="true"
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
SLO_MAX_P95_LATENCY_MS="4000"
SLO_MAX_FALLBACK_RATE="0.25"
SLO_MAX_READY_FAILURES="0"
ALERT_WEBHOOK_URL=""

# Telegram (optional): risk alerts and Gem alerts with buttons (אשר סימולציה / ניתוח עמוק / התעלם).
# For interactive buttons, set bot webhook: POST https://api.telegram.org/bot<TOKEN>/setWebhook?url=<APP_URL>/api/telegram/webhook
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# Optional: when Binance API returns 451 (region block), use this proxy base URL for klines
# PROXY_BINANCE_URL="https://your-proxy.com/binance"
PROXY_BINANCE_URL=""

# Base URL for server-side fetch (required in production). Priority: NEXT_PUBLIC_APP_URL → APP_URL → VERCEL_URL (auto) → localhost
NEXT_PUBLIC_APP_URL=""
APP_URL="https://www.moncherigroup.co.il"
