# API Keys (Secured & Quoted)
GEMINI_API_KEY=your_gemini_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GROQ_API_KEY=your_groq_api_key_here
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=your_pinecone_index_name
PINECONE_EMBEDDING_DIM=1024
NEWS_API_KEY=your_news_api_key_here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Database
DB_DRIVER="file"
SQLITE_DB_PATH="predictions.sqlite"
# Production: DATABASE_URL user must be quantum_admin; never postgres (see lib/db/sovereign-db-url.ts).
# Development: any PostgreSQL user except postgres is allowed from DATABASE_URL alone.
# Optional: set QUANTUM_SOVEREIGN_DB_USER (or QUANTUM_ADMIN) to require the URL user to match that name locally.
# QUANTUM_SOVEREIGN_DB_USER=
DATABASE_URL=postgresql://quantum_admin:PASSWORD@host:5432/dbname?schema=public

# Settings & Thresholds
ANALYSIS_RATE_LIMIT_MAX="12"
ANALYSIS_RATE_LIMIT_WINDOW_MS="60000"
ANALYSIS_DEDUP_WINDOW_MS="30000"
GEMINI_MODEL_FALLBACK="gemini-3-flash-preview"
GEMINI_MODEL_QUOTA_FALLBACK="gemini-3-flash-preview"
GEMINI_MODEL_PRIMARY="gemini-3-flash-preview"
MAX_FETCH_RETRIES="3"
MIN_HUMAN_DELAY_MS="1200"
AUDIT_LOG_ENABLED="true"
SLO_MAX_P95_LATENCY_MS="4000"
SLO_MAX_FALLBACK_RATE="0.25"
SLO_MAX_READY_FAILURES="0"
ADMIN_SECRET=your_admin_secret_here

# App Context
APP_URL="http://localhost:3000"
# Optional public site URL for links in emails/Telegram. Never put secrets in NEXT_PUBLIC_* — those vars are shipped to the browser.
# NEXT_PUBLIC_APP_URL=

# Authentication & Security
APP_SESSION_SECRET="your_session_secret_here"
ADMIN_LOGIN_PASSWORD="admin"
VIEWER_LOGIN_PASSWORD="viewer"
WORKER_CRON_SECRET=your_cron_secret_here
CRYPTOQUANT_API_KEY=your_cryptoquant_api_key_here
CMC_API_KEY=your_cmc_api_key_here
