# API Keys (Secured & Quoted)
GEMINI_API_KEY=your_gemini_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GROQ_API_KEY=your_groq_api_key_here
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=your_pinecone_index_name
PINECONE_EMBEDDING_DIM=1024
NEWS_API_KEY=your_news_api_key_here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Database — PostgreSQL only. No SQLite fallback.
# Local:  postgresql://postgres:PASSWORD@127.0.0.1:5432/quntum_mon_cheri
# Remote: postgresql://USER:PASSWORD@host:5432/dbname
# Runtime validates protocol + parseability — see lib/db/sovereign-db-url.ts.
DATABASE_URL=postgresql://postgres:CHANGE_ME@127.0.0.1:5432/quntum_mon_cheri

# Settings & Thresholds
ANALYSIS_RATE_LIMIT_MAX="12"
ANALYSIS_RATE_LIMIT_WINDOW_MS="60000"
ANALYSIS_DEDUP_WINDOW_MS="30000"
GEMINI_MODEL_FALLBACK="gemini-3-flash-preview"
GEMINI_MODEL_QUOTA_FALLBACK="gemini-3-flash-preview"
GEMINI_MODEL_PRIMARY="gemini-3-flash-preview"
MAX_FETCH_RETRIES="3"
MIN_HUMAN_DELAY_MS="1200"
AUDIT_LOG_ENABLED="true"
SLO_MAX_P95_LATENCY_MS="4000"
SLO_MAX_FALLBACK_RATE="0.25"
SLO_MAX_READY_FAILURES="0"
ADMIN_SECRET=your_admin_secret_here

# App Context
APP_URL="http://localhost:3000"
# Optional public site URL for links in emails/Telegram. Never put secrets in NEXT_PUBLIC_* — those vars are shipped to the browser.
# NEXT_PUBLIC_APP_URL=

# Authentication & Security
APP_SESSION_SECRET="your_session_secret_here"
ADMIN_LOGIN_PASSWORD="admin"
VIEWER_LOGIN_PASSWORD="viewer"
WORKER_CRON_SECRET=your_cron_secret_here
CRYPTOQUANT_API_KEY=your_cryptoquant_api_key_here
CMC_API_KEY=your_cmc_api_key_here

# Optional / integrations (see lib/config.ts, lib/env.ts, lib/cron-auth.ts)
# ALLOWED_IPS=
# OPERATOR_LOGIN_PASSWORD=
# CRON_SECRET=
# APP_SESSION_SECRET_PREVIOUS=
# NEXT_PUBLIC_APP_URL=
# TELEGRAM_ADMIN_CHAT_ID=
# PROXY_BINANCE_URL=
# Python Signal Core (CVD / entropy / Kalman) — see services/signal-core/README.md
# SIGNAL_CORE_URL=http://127.0.0.1:8765
# SIGNAL_CORE_ENABLED=1
# SIGNAL_CORE_TIMEOUT_MS=8000
# (Client honors 100–60000 ms; values outside range fall back to 8000 ms.)
# IS_LIVE_MODE=false
# AI_PROVIDER=gemini
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_COMPAT_BASE_URL=https://api.openai.com/v1
# GROQ_MODEL=llama-3.1-8b-instant
# GEMINI_EMBEDDING_MODEL_ID=
# GEMINI_TIMEOUT_MS=60000
# DISABLE_HMR=false
# APP_AUTH_TOKEN=
# TURNSTILE_SECRET_KEY=
# DB_BACKUP_KEEP=7
# SCANNER_DELAY_BETWEEN_SYMBOLS_MS=350
# PAPER_SLIPPAGE_BPS=5
# PAPER_LIQUIDATION_PCT=-75
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ──────────────────────────────────────────────────────────────
# Enterprise Queue & Alpha Matrix (BullMQ)
# ──────────────────────────────────────────────────────────────
# TCP-compatible Redis URL for BullMQ (different from the REST URL above).
# Upstash → Dashboard → Connect → ioredis → copy the rediss:// URL.
# REDIS_URL=rediss://default:<token>@<host>:<port>

# Set to true to activate BullMQ queue mode (requires REDIS_URL + PM2 queue-worker).
# When false (default), the legacy sequential scanner is used.
# QUEUE_ENABLED=false

# Number of coins processed in parallel by the BullMQ worker (default: 3).
# QUEUE_CONCURRENCY=3

# Per-job analysis timeout in milliseconds (default: 150000 = 2.5 min).
# QUEUE_JOB_TIMEOUT_MS=150000

# ── Circuit Breaker ──────────────────────────────────────────
# Number of consecutive non-429 failures before opening a breaker (default: 5).
# CB_FAILURE_THRESHOLD=5

# Sliding window in seconds for counting failures (default: 60).
# CB_FAILURE_WINDOW_S=60

# Milliseconds before a OPEN breaker enters HALF_OPEN recovery (default: 300000 = 5 min).
# CB_RECOVERY_MS=300000

# ── Webhook Delivery ─────────────────────────────────────────
# HTTP endpoint to POST the final AlphaReportPayload JSON to.
# Leave unset to disable webhook delivery.
# WEBHOOK_URL=https://your-service.example.com/api/alpha-report
# TYPECHECK_PASSED=
# GLASSNODE_API_KEY=
# CRYPTOCOMPARE_API_KEY=
# CLAUDE_API_KEY=
# XAI_API_KEY=
# EXCHANGE_API_KEY=
# EXCHANGE_SECRET=
# EXCHANGE_TESTNET=false
# BINANCE_API_KEY=
# BINANCE_SECRET=
# FRED_API_KEY=
# GEMINI_CONTRARIAN_MODEL=gemini-2.5-flash
# MACRO_EXPERT_USE_GROQ=0
# EXECUTION_RSA_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
# EXECUTION_RSA_MAX_SKEW_MS=60000
