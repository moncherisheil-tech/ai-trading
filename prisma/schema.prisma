generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TradeExecutionType {
  PAPER
  LIVE
}

enum TradeSide {
  BUY
  SELL
}

enum TradeExecutionStatus {
  OPEN
  CLOSED
  FAILED
}

model TradeExecution {
  id            String               @id @default(cuid())
  symbol        String
  alphaSignalId String?
  type          TradeExecutionType
  side          TradeSide
  amount        Decimal              @db.Decimal(24, 8)
  entryPrice    Decimal              @db.Decimal(24, 8)
  exitPrice     Decimal?             @db.Decimal(24, 8)
  pnl           Decimal?             @db.Decimal(24, 8)
  status        TradeExecutionStatus @default(OPEN)
  executedAt    DateTime             @default(now())
  closedAt      DateTime?

  insights      LearnedInsight[]

  @@index([symbol, executedAt(sort: Desc)])
  @@index([status, executedAt(sort: Desc)])
}

model LearnedInsight {
  id                String   @id @default(cuid())
  tradeId           String
  failureReason     String
  academyReference  String?
  adjustmentApplied Boolean  @default(false)
  createdAt         DateTime @default(now())

  trade             TradeExecution @relation(fields: [tradeId], references: [id], onDelete: Cascade)

  @@index([tradeId, createdAt(sort: Desc)])
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt

  @@map("settings")
}

/// Matches `telegram_subscribers` (see `lib/db.ts` init + `lib/db/telegram-subscribers.ts` raw SQL).
model TelegramSubscriber {
  id        Int      @id @default(autoincrement())
  chatId    String   @unique @map("chat_id")
  username  String?
  isActive  Boolean  @default(true) @map("is_active")
  role      String   @default("subscriber")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("telegram_subscribers")
}
